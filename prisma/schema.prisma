generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  phone     String
  password  String
  role      String   @default("player")
  isBlocked Boolean  @default(false)
  createdAt DateTime @default(now())

  wallet       Wallet?
  bankAccount  BankAccount[]
  transactions Transaction[]
  withdrawals  Withdrawal[]

  deposits  Deposit[]
  adminLogs AdminLog[]
  ledgers       Ledger[]
}

model Wallet {
  id          Int   @id @default(autoincrement())
  userId      Int   @unique
  balance     Float @default(0)
  holdBalance Float @default(0)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model BankAccount {
  id            Int     @id @default(autoincrement())
  userId        Int
  paymentMethod String?
  bankName      String
  accountName   String
  accountNumber String @unique

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Transaction {
  id            Int      @id @default(autoincrement())
  userId        Int
  type          String
  amount        Float
  beforeBalance Float
  afterBalance  Float
  description   String
  status        String   @default("success")
  reference     String?  @unique
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model Withdrawal {
  id     Int   @id @default(autoincrement())
  userId Int
  amount Float

  status String @default("pending")

  beforeBalance Float
  afterBalance  Float

  bankName      String
  accountName   String
  accountNumber String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model Deposit {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Float
  status    String   @default("pending") // pending, approved, rejected
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model AdminLog {
  id        Int      @id @default(autoincrement())
  adminId   Int
  action    String
  targetId  Int?
  meta      Json?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])
}

model Ledger {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // deposit, withdraw, inject, refund
  amount    Float
  direction String   // credit | debit
  before    Float
  after     Float
  refId     Int?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model WebSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
